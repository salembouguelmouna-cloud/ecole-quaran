<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#047857">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon-192.png">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <title>متابعة <%= student.name %> - منارة حميم</title>
  <script>
    tailwind.config={darkMode:"class"};
    if (localStorage.getItem("dark")==="true") document.documentElement.classList.add("dark");
  </script>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css">
  <script>if ('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js');</script>
  <script>
    function toggleMenu() { document.getElementById('mobileMenu').classList.toggle('hidden'); }
    function toggleDark() { document.documentElement.classList.toggle('dark'); localStorage.setItem('dark', document.documentElement.classList.contains('dark')); }
    </script>
</head>
<body class="bg-gradient-to-br from-emerald-50 to-teal-100 dark:from-gray-900 dark:to-gray-800 min-h-screen transition-colors">
  <nav class="gradient-main text-white shadow-lg">
    <div class="max-w-4xl mx-auto px-4 py-3 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <% if (admin && admin.logo) { %><img src="<%= admin.logo %>" class="w-9 h-9 rounded-lg object-cover"><% } else { %><span class="w-9 h-9 bg-white/20 rounded-lg flex items-center justify-center text-lg">🕌</span><% } %>
        <span class="font-bold text-lg">منارة حميم</span>
      </div>
      <div class="hidden md:flex items-center gap-3">
        <span class="text-emerald-100 text-sm bg-white/10 px-3 py-1 rounded-full">مرحبا، <%= user.name %></span>
        <button onclick="toggleDark()" class="text-white hover:bg-white/20 px-3 py-1.5 rounded-lg text-sm">🌓</button>
        <a href="/logout" class="bg-red-500/80 hover:bg-red-500 px-3 py-1.5 rounded-lg text-sm">خروج</a>
      </div>
      <button class="md:hidden text-2xl" onclick="toggleMenu()">☰</button>
    </div>
    <div id="mobileMenu" class="hidden md:hidden px-4 pb-3 space-y-2">
      <button onclick="toggleDark()" class="block w-full text-right hover:bg-white/10 px-3 py-2 rounded-lg text-sm">🌓 الوضع الليلي</button>
      <a href="/logout" class="block bg-red-500/80 hover:bg-red-500 px-3 py-2 rounded-lg text-sm">خروج</a>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-4 py-6">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-emerald-100 dark:border-emerald-900 p-6 mb-6 card-hover">
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 bg-emerald-100 dark:bg-emerald-900/50 rounded-2xl flex items-center justify-center text-2xl">🧑‍🎓</div>
        <div>
          <h1 class="text-2xl font-bold text-gray-800 dark:text-white"><%= student.name %></h1>
          <p class="text-gray-500 dark:text-gray-400 text-sm flex items-center gap-2 flex-wrap mt-1">
            <span class="bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 px-2 py-0.5 rounded-full text-xs font-medium"><%= student.level || 'غير محدد' %></span>
            <span>مسجل منذ <%= new Date(student.created_at).toLocaleDateString('ar-MA') %></span>
          </p>
          <% if (admin) { %>
            <p class="text-gray-500 dark:text-gray-400 text-xs mt-2 flex items-center gap-2 flex-wrap">
              <span>🕌 <%= admin.school_name %></span>
              <% if (admin.phone) { %>
                <span>|</span>
                <span>📞 <a href="tel:<%= admin.phone %>" class="text-emerald-600 dark:text-emerald-400 hover:underline font-medium" dir="ltr"><%= admin.phone %></a></span>
                <span>|</span>
                <span>💬 <a href="https://wa.me/<%= admin.phone.replace(/[^0-9]/g,'') %>" target="_blank" class="text-green-600 dark:text-green-400 hover:underline font-medium">واتساب</a></span>
              <% } %>
            </p>
          <% } %>
        </div>
      </div>
    </div>

    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-bold text-gray-800 dark:text-white">سجل الحصص</h2>
      <span class="text-xs text-gray-400 dark:text-gray-500 bg-white dark:bg-gray-800 px-2 py-1 rounded-full shadow-sm"><%= progress.length %> حصة</span>
    </div>

    <% if (progress.length === 0) { %>
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 p-8 text-center text-gray-400 dark:text-gray-500">
        <div class="text-4xl mb-2">📅</div>
        <p>لا توجد حصص مسجلة بعد.</p>
      </div>
    <% } %>

    <div class="space-y-3">
      <% progress.forEach(p => { %>
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 p-5 card-hover">
          <div class="flex items-start justify-between mb-3">
            <div class="flex items-center gap-2">
              <span class="text-lg"><%= p.presence ? '✅' : '❌' %></span>
              <span class="font-semibold text-gray-800 dark:text-white"><%= p.date %></span>
              <span class="<%= p.presence ? 'text-emerald-600 dark:text-emerald-400' : 'text-red-500 dark:text-red-400' %> text-sm font-medium">
                <%= p.presence ? 'حاضر' : 'غائب' %>
              </span>
            </div>
            <% if (p.behavior) { %>
              <span class="text-xs px-3 py-1 rounded-full font-medium
                <%= p.behavior === 'جيد' ? 'bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400' : '' %>
                <%= p.behavior === 'متوسط' ? 'bg-amber-50 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400' : '' %>
                <%= p.behavior === 'يحتاج تحسين' ? 'bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-400' : '' %>">
                <%= p.behavior %>
              </span>
            <% } %>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-3">
            <% if (p.memorization) { %>
              <div class="bg-emerald-50/50 dark:bg-emerald-900/20 rounded-xl p-3">
                <span class="text-xs font-bold text-emerald-700 dark:text-emerald-400">📖 الحفظ</span>
                <p class="text-gray-700 dark:text-gray-300 text-sm mt-1"><%= p.memorization %></p>
              </div>
            <% } %>
            <% if (p.revision) { %>
              <div class="bg-blue-50/50 dark:bg-blue-900/20 rounded-xl p-3">
                <span class="text-xs font-bold text-blue-700 dark:text-blue-400">🔄 المراجعة</span>
                <p class="text-gray-700 dark:text-gray-300 text-sm mt-1"><%= p.revision %></p>
              </div>
            <% } %>
          </div>

          <% if (p.notes) { %>
            <div class="mt-3 pt-3 border-t border-gray-100 dark:border-gray-700">
              <span class="text-xs font-bold text-gray-500 dark:text-gray-400">📝 ملاحظات</span>
              <p class="text-gray-600 dark:text-gray-400 text-sm mt-1"><%= p.notes %></p>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>
  </main>
</body>
</html>