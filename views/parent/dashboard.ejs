<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#047857">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon-192.png">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <title>متابعة <%= student.name %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>if ('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js');</script>
</head>
<body class="bg-gradient-to-br from-emerald-50 to-teal-100 min-h-screen">
  <nav class="bg-emerald-700 text-white shadow-lg">
    <div class="max-w-4xl mx-auto px-4 py-3 flex justify-between items-center">
      <div class="flex items-center gap-2">
        <span class="text-xl">📖</span>
        <span class="font-semibold">مدرسة القرآن</span>
      </div>
      <div class="flex items-center gap-4">
        <span class="text-emerald-100 text-sm">مرحبا، <%= user.name %></span>
        <a href="/logout" class="bg-emerald-600 hover:bg-emerald-500 px-3 py-1.5 rounded text-sm transition">خروج</a>
      </div>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-4 py-6">
    <div class="bg-white rounded-2xl shadow-xl p-6 mb-6">
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center text-2xl">
          🧑‍🎓
        </div>
        <div>
          <h1 class="text-2xl font-bold text-gray-800"><%= student.name %></h1>
          <p class="text-gray-500 flex items-center gap-2 flex-wrap">
            <span class="bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full text-xs font-medium"><%= student.level || 'غير محدد' %></span>
            <span>مسجل منذ <%= new Date(student.created_at).toLocaleDateString('ar-MA') %></span>
          </p>
        </div>
      </div>
    </div>

    <h2 class="text-xl font-bold text-gray-800 mb-4">سجل الحصص</h2>

    <% if (progress.length === 0) { %>
      <div class="bg-white rounded-xl shadow p-8 text-center text-gray-400">
        لا توجد حصص مسجلة بعد.
      </div>
    <% } %>

    <div class="space-y-3">
      <% progress.forEach(p => { %>
        <div class="bg-white rounded-xl shadow p-4 hover:shadow-md transition">
          <div class="flex items-start justify-between mb-2">
            <div class="flex items-center gap-2">
              <span class="text-lg"><%= p.presence ? '✅' : '❌' %></span>
              <span class="font-semibold text-gray-800"><%= p.date %></span>
              <span class="<%= p.presence ? 'text-emerald-600' : 'text-red-500' %> text-sm font-medium">
                <%= p.presence ? 'حاضر' : 'غائب' %>
              </span>
            </div>
            <% if (p.behavior) { %>
              <span class="text-xs px-2 py-1 rounded-full font-medium
                <%= p.behavior === 'جيد' ? 'bg-emerald-100 text-emerald-700' : '' %>
                <%= p.behavior === 'متوسط' ? 'bg-amber-100 text-amber-700' : '' %>
                <%= p.behavior === 'يحتاج تحسين' ? 'bg-red-100 text-red-700' : '' %>">
                <%= p.behavior %>
              </span>
            <% } %>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-3">
            <% if (p.memorization) { %>
              <div>
                <span class="text-xs font-semibold text-emerald-600 uppercase tracking-wide">الحفظ</span>
                <p class="text-gray-700 text-sm mt-0.5"><%= p.memorization %></p>
              </div>
            <% } %>
            <% if (p.revision) { %>
              <div>
                <span class="text-xs font-semibold text-blue-600 uppercase tracking-wide">المراجعة</span>
                <p class="text-gray-700 text-sm mt-0.5"><%= p.revision %></p>
              </div>
            <% } %>
          </div>

          <% if (p.notes) { %>
            <div class="mt-2 pt-2 border-t border-gray-100">
              <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">ملاحظات</span>
              <p class="text-gray-600 text-sm mt-0.5"><%= p.notes %></p>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>
  </main>
</body>
</html>
