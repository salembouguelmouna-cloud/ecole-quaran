<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#047857">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon-192.png">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <title><%= student.name %> - متابعة</title>
  <script>
    tailwind.config={darkMode:"class"};
    if (localStorage.getItem("dark")==="true") document.documentElement.classList.add("dark");
  </script>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css">
  <script>if ('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js');</script>
  <script>
    function toggleMenu() { document.getElementById('mobileMenu').classList.toggle('hidden'); }
    function toggleDark() { document.documentElement.classList.toggle('dark'); localStorage.setItem('dark', document.documentElement.classList.contains('dark')); }
    </script>
</head>
<body class="bg-gray-50 dark:bg-gray-900 min-h-screen transition-colors">
  <nav class="gradient-main text-white shadow-lg">
    <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <% if (admin.logo) { %><img src="<%= admin.logo %>" class="w-9 h-9 rounded-lg object-cover"><% } else { %><span class="w-9 h-9 bg-white/20 rounded-lg flex items-center justify-center text-lg">🕌</span><% } %>
        <span class="font-bold text-lg"><%= admin.schoolName || 'منارة حميم' %></span>
      </div>
      <div class="hidden md:flex items-center gap-3">
        <span class="text-emerald-100 text-sm bg-white/10 px-3 py-1 rounded-full"><%= admin.name %></span>
        <a href="/admin/dashboard" class="text-white hover:bg-white/20 px-3 py-1.5 rounded-lg text-sm">لوحة التحكم</a>
        <a href="/admin/students" class="text-white hover:bg-white/20 px-3 py-1.5 rounded-lg text-sm">التلاميذ</a>
        <a href="/admin/ranking" class="text-white hover:bg-white/20 px-3 py-1.5 rounded-lg text-sm">🏆 الترتيب</a>
            <a href="/admin/calendar" class="text-white hover:bg-white/20 px-3 py-1.5 rounded-lg text-sm">📆 التقويم</a>
            <a href="/admin/settings" class="text-white hover:bg-white/20 px-3 py-1.5 rounded-lg text-sm">الإعدادات</a>
        <button onclick="toggleDark()" class="text-white hover:bg-white/20 px-3 py-1.5 rounded-lg text-sm">🌓</button>
        <a href="/logout" class="bg-red-500/80 hover:bg-red-500 px-3 py-1.5 rounded-lg text-sm">خروج</a>
      </div>
      <button class="md:hidden text-2xl" onclick="toggleMenu()">☰</button>
    </div>
    <div id="mobileMenu" class="hidden md:hidden px-4 pb-3 space-y-2">
      <a href="/admin/dashboard" class="block hover:bg-white/10 px-3 py-2 rounded-lg text-sm">لوحة التحكم</a>
      <a href="/admin/students" class="block hover:bg-white/10 px-3 py-2 rounded-lg text-sm">التلاميذ</a>
      <a href="/admin/ranking" class="block hover:bg-white/10 px-3 py-2 rounded-lg text-sm">🏆 الترتيب</a>
      <a href="/admin/calendar" class="block hover:bg-white/10 px-3 py-2 rounded-lg text-sm">📆 التقويم</a>
      <a href="/admin/settings" class="block hover:bg-white/10 px-3 py-2 rounded-lg text-sm">الإعدادات</a>
      <button onclick="toggleDark()" class="block w-full text-right hover:bg-white/10 px-3 py-2 rounded-lg text-sm">🌓 الوضع الليلي</button>
      <a href="/logout" class="block bg-red-500/80 hover:bg-red-500 px-3 py-2 rounded-lg text-sm">خروج</a>
    </div>
  </nav>

  <main class="max-w-7xl mx-auto px-4 py-6">
    <div class="flex flex-col sm:flex-row justify-between items-start gap-4 mb-6">
      <div>
        <div class="flex items-center gap-3 mb-1">
          <span class="w-10 h-10 bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-400 rounded-xl flex items-center justify-center text-lg font-bold"><%= student.name.charAt(0) %></span>
          <h1 class="text-2xl font-bold text-gray-800 dark:text-white"><%= student.name %></h1>
        </div>
        <p class="text-gray-500 dark:text-gray-400 text-sm mt-2 flex items-center gap-2 flex-wrap">
          <span class="bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 px-3 py-1 rounded-full text-xs font-medium"><%= student.level || 'غير محدد' %></span>
          <span>👤 <%= student.parent_name %></span>
          <% if (student.parent_phone) { %><span>📞 <a href="tel:<%= student.parent_phone %>" class="text-emerald-600 dark:text-emerald-400 hover:underline" dir="ltr"><%= student.parent_phone %></a></span><% } %>
          <span class="text-gray-400">|</span>
          <span>🔑 <code class="bg-gray-100 dark:bg-gray-700 px-2 py-0.5 rounded text-emerald-700 dark:text-emerald-400 text-xs font-mono" dir="ltr"><%= student.parent_username %></code></span>
        </p>
      </div>
      <div class="flex gap-2 flex-wrap">
        <a href="/admin/students/edit/<%= student.id %>" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2.5 rounded-xl text-sm font-medium transition shadow-md flex items-center gap-1.5">✏️ تعديل</a>
        <a href="/admin/progress/add/<%= student.id %>" class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2.5 rounded-xl text-sm font-medium transition shadow-md flex items-center gap-1.5"><span class="text-lg">+</span> إضافة حصة</a>
        <a href="/admin/card/<%= student.id %>" target="_blank" class="bg-amber-600 hover:bg-amber-700 text-white px-4 py-2.5 rounded-xl text-sm font-medium transition shadow-md flex items-center gap-1.5">🪪 بطاقة</a>
        <a href="/admin/qrcode/<%= student.id %>" target="_blank" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2.5 rounded-xl text-sm font-medium transition shadow-md flex items-center gap-1.5">📱 QR</a>
        <a href="/admin/students/delete/<%= student.id %>" class="bg-red-500 hover:bg-red-600 text-white px-4 py-2.5 rounded-xl text-sm font-medium transition shadow-md flex items-center gap-1.5" onclick="return confirm('هل أنت متأكد من حذف التلميذ <%= student.name %>؟\nسيتم حذف جميع حصصه أيضاً.')">🗑️ حذف</a>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 dark:border-gray-700 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-3">
        <h2 class="font-bold text-gray-800 dark:text-white">سجل الحصص</h2>
        <div class="flex items-center gap-3">
          <input type="text" id="searchProgress" placeholder="🔍 بحث..." oninput="filterProgress()" class="px-3 py-1.5 border border-gray-200 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-lg text-sm outline-none focus:ring-2 focus:ring-emerald-500 w-full sm:w-48">
          <span class="text-xs text-gray-400 dark:text-gray-500 bg-gray-50 dark:bg-gray-700 px-2 py-1 rounded-full"><%= progress.length %> حصة</span>
        </div>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full" id="progressTable">
          <thead>
            <tr class="bg-gray-50 dark:bg-gray-800/50 text-right text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              <th class="px-5 py-3">التاريخ</th>
              <th class="px-5 py-3">الحضور</th>
              <th class="px-5 py-3">الحفظ</th>
              <th class="px-5 py-3">المراجعة</th>
              <th class="px-5 py-3">السلوك</th>
              <th class="px-5 py-3">ملاحظات</th>
              <th class="px-5 py-3">الإجراءات</th>
            </tr>
          </thead>
          <tbody>
            <% if (progress.length === 0) { %>
              <tr><td colspan="7" class="px-5 py-12 text-center text-gray-400 dark:text-gray-500">
                <div class="text-4xl mb-2">📅</div>
                <p>لا توجد حصص مسجلة</p>
                <a href="/admin/progress/add/<%= student.id %>" class="text-emerald-600 dark:text-emerald-400 hover:text-emerald-800 text-sm font-medium mt-1 inline-block">أضف أول حصة</a>
              </td></tr>
            <% } %>
            <% progress.forEach(p => { %>
              <tr class="border-t border-gray-100 dark:border-gray-700 hover:bg-emerald-50/50 dark:hover:bg-gray-700/50 transition progress-row">
                <td class="px-5 py-4 font-medium text-gray-800 dark:text-white whitespace-nowrap"><%= p.date %></td>
                <td class="px-5 py-4">
                  <span class="inline-flex items-center gap-1.5 <%= p.presence ? 'text-emerald-600 dark:text-emerald-400' : 'text-red-500 dark:text-red-400' %> font-medium">
                    <span class="w-2 h-2 rounded-full <%= p.presence ? 'bg-emerald-500' : 'bg-red-500' %>"></span>
                    <%= p.presence ? 'حاضر' : 'غائب' %>
                  </span>
                </td>
                <td class="px-5 py-4 text-gray-600 dark:text-gray-400"><%= p.memorization || '-' %></td>
                <td class="px-5 py-4 text-gray-600 dark:text-gray-400"><%= p.revision || '-' %></td>
                <td class="px-5 py-4">
                  <% if (p.behavior) { %>
                    <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= p.behavior === 'جيد' ? 'bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400' : p.behavior === 'متوسط' ? 'bg-amber-50 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400' : 'bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-400' %>"><%= p.behavior %></span>
                  <% } else { %>-<% } %>
                </td>
                <td class="px-5 py-4 text-gray-500 dark:text-gray-500 max-w-[200px] truncate"><%= p.notes || '-' %></td>
                <td class="px-5 py-4">
                  <div class="flex items-center gap-2">
                    <a href="/admin/progress/edit/<%= p.id %>" class="text-emerald-600 dark:text-emerald-400 hover:text-emerald-800 text-sm font-medium bg-emerald-50 dark:bg-emerald-900/30 hover:bg-emerald-100 dark:hover:bg-emerald-900/50 px-3 py-1.5 rounded-lg transition">تعديل</a>
                    <a href="/admin/progress/delete/<%= p.id %>" class="text-red-500 dark:text-red-400 hover:text-red-700 text-sm font-medium bg-red-50 dark:bg-red-900/30 hover:bg-red-100 dark:hover:bg-red-900/50 px-3 py-1.5 rounded-lg transition" onclick="return confirm('هل أنت متأكد من حذف هذه الحصة؟')">حذف</a>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <script>
    function filterProgress() {
      const q = document.getElementById('searchProgress').value.toLowerCase();
      document.querySelectorAll('.progress-row').forEach(r => {
        r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
    }
  </script>
</body>
</html>