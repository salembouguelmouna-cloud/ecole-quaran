<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#047857">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon-192.png">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <title>لوحة التحكم - <%= admin.schoolName || 'منارة حميم' %></title>
  <script>
    tailwind.config={darkMode:"class"};
    if (localStorage.getItem("dark")==="true") document.documentElement.classList.add("dark");
  </script>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css">
  <script>if ('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js');</script>
  <script>
    function toggleMenu() {
      document.getElementById('mobileMenu').classList.toggle('hidden');
    }
    function toggleDark() {
      document.documentElement.classList.toggle('dark');
      localStorage.setItem('dark', document.documentElement.classList.contains('dark'));
    }
    </script>
</head>
<body class="bg-gray-50 dark:bg-gray-900 min-h-screen transition-colors">
  <nav class="gradient-main text-white shadow-lg">
    <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <% if (admin.logo) { %><img src="<%= admin.logo %>" class="w-9 h-9 rounded-lg object-cover"><% } else { %><span class="w-9 h-9 bg-white/20 rounded-lg flex items-center justify-center text-lg">🕌</span><% } %>
        <span class="font-bold text-lg"><%= admin.schoolName || 'منارة حميم' %></span>
      </div>
      <div class="hidden md:flex items-center gap-3">
        <span class="text-emerald-100 text-sm bg-white/10 px-3 py-1 rounded-full"><%= admin.name %></span>
        <a href="/admin/dashboard" class="bg-white/20 text-white px-3 py-1.5 rounded-lg text-sm font-medium">لوحة التحكم</a>
        <a href="/admin/students" class="text-white hover:bg-white/20 px-3 py-1.5 rounded-lg text-sm">التلاميذ</a>
        <a href="/admin/ranking" class="text-white hover:bg-white/20 px-3 py-1.5 rounded-lg text-sm">🏆 الترتيب</a>
            <a href="/admin/calendar" class="text-white hover:bg-white/20 px-3 py-1.5 rounded-lg text-sm">📆 التقويم</a>
            <a href="/admin/settings" class="text-white hover:bg-white/20 px-3 py-1.5 rounded-lg text-sm">الإعدادات</a>
        <a href="/admin/export/csv" class="text-white hover:bg-white/20 px-3 py-1.5 rounded-lg text-sm">📥 تصدير</a>
        <button onclick="toggleDark()" class="text-white hover:bg-white/20 px-3 py-1.5 rounded-lg text-sm">🌓</button>
        <a href="/logout" class="bg-red-500/80 hover:bg-red-500 px-3 py-1.5 rounded-lg text-sm">خروج</a>
      </div>
      <button class="md:hidden text-2xl" onclick="toggleMenu()">☰</button>
    </div>
    <div id="mobileMenu" class="hidden md:hidden px-4 pb-3 space-y-2">
      <a href="/admin/dashboard" class="block bg-white/20 px-3 py-2 rounded-lg text-sm">لوحة التحكم</a>
      <a href="/admin/students" class="block hover:bg-white/10 px-3 py-2 rounded-lg text-sm">التلاميذ</a>
      <a href="/admin/ranking" class="block hover:bg-white/10 px-3 py-2 rounded-lg text-sm">🏆 الترتيب</a>
      <a href="/admin/calendar" class="block hover:bg-white/10 px-3 py-2 rounded-lg text-sm">📆 التقويم</a>
      <a href="/admin/settings" class="block hover:bg-white/10 px-3 py-2 rounded-lg text-sm">الإعدادات</a>
      <a href="/admin/export/csv" class="block hover:bg-white/10 px-3 py-2 rounded-lg text-sm">📥 تصدير CSV</a>
      <button onclick="toggleDark()" class="block w-full text-right hover:bg-white/10 px-3 py-2 rounded-lg text-sm">🌓 الوضع الليلي</button>
      <a href="/logout" class="block bg-red-500/80 hover:bg-red-500 px-3 py-2 rounded-lg text-sm">خروج</a>
    </div>
  </nav>

  <main class="max-w-7xl mx-auto px-4 py-6">
    <div class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-2xl font-bold text-gray-800 dark:text-white">لوحة التحكم</h1>
        <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">مرحبا بك في منصة متابعة التلاميذ</p>
      </div>
      <div class="flex gap-2">
        <a href="/admin/export/csv" class="bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 px-4 py-2.5 rounded-xl text-sm font-medium transition flex items-center gap-2">📥</a>
        <a href="/admin/students/add" class="bg-emerald-600 hover:bg-emerald-700 text-white px-5 py-2.5 rounded-xl text-sm font-medium transition shadow-md hover:shadow-lg flex items-center gap-2">
          <span class="text-lg">+</span> إضافة تلميذ
        </a>
      </div>
    </div>

    <% if (stats) { %>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 mb-8">
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-4 md:p-5 border border-emerald-100 dark:border-emerald-900 card-hover">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 md:w-12 md:h-12 bg-emerald-100 dark:bg-emerald-900/50 rounded-xl flex items-center justify-center text-emerald-600 dark:text-emerald-400 text-xl">👥</div>
          <div class="min-w-0">
            <p class="text-gray-500 dark:text-gray-400 text-xs font-medium">التلاميذ</p>
            <p class="text-xl md:text-2xl font-bold text-gray-800 dark:text-white"><%= stats.totalStudents %></p>
          </div>
        </div>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-4 md:p-5 border border-amber-100 dark:border-amber-900 card-hover">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 md:w-12 md:h-12 bg-amber-100 dark:bg-amber-900/50 rounded-xl flex items-center justify-center text-amber-600 dark:text-amber-400 text-xl">📖</div>
          <div class="min-w-0">
            <p class="text-gray-500 dark:text-gray-400 text-xs font-medium">السور</p>
            <p class="text-xl md:text-2xl font-bold text-gray-800 dark:text-white"><%= stats.totalLevels %></p>
          </div>
        </div>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-4 md:p-5 border border-blue-100 dark:border-blue-900 card-hover">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 md:w-12 md:h-12 bg-blue-100 dark:bg-blue-900/50 rounded-xl flex items-center justify-center text-blue-600 dark:text-blue-400 text-xl">✅</div>
          <div class="min-w-0">
            <p class="text-gray-500 dark:text-gray-400 text-xs font-medium">نسبة الحضور</p>
            <p class="text-xl md:text-2xl font-bold text-gray-800 dark:text-white"><%= stats.attendanceRate %>%</p>
          </div>
        </div>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-4 md:p-5 border border-purple-100 dark:border-purple-900 card-hover">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 md:w-12 md:h-12 bg-purple-100 dark:bg-purple-900/50 rounded-xl flex items-center justify-center text-purple-600 dark:text-purple-400 text-xl">📊</div>
          <div class="min-w-0">
            <p class="text-gray-500 dark:text-gray-400 text-xs font-medium">الحصص</p>
            <p class="text-xl md:text-2xl font-bold text-gray-800 dark:text-white"><%= stats.totalSessions %></p>
          </div>
        </div>
      </div>
    </div>
    <% } %>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8">
      <a href="/admin/ranking" class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-4 border border-amber-100 dark:border-amber-900 card-hover hover:shadow-md transition flex flex-col items-center gap-1.5 text-center">
        <span class="text-2xl">🏆</span>
        <span class="text-sm font-bold text-gray-700 dark:text-gray-200">الترتيب</span>
      </a>
      <a href="/admin/calendar" class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-4 border border-cyan-100 dark:border-cyan-900 card-hover hover:shadow-md transition flex flex-col items-center gap-1.5 text-center">
        <span class="text-2xl">📆</span>
        <span class="text-sm font-bold text-gray-700 dark:text-gray-200">التقويم</span>
      </a>
      <a href="/admin/export/csv" class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-4 border border-blue-100 dark:border-blue-900 card-hover hover:shadow-md transition flex flex-col items-center gap-1.5 text-center">
        <span class="text-2xl">📥</span>
        <span class="text-sm font-bold text-gray-700 dark:text-gray-200">CSV</span>
      </a>
      <a href="/admin/settings" class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-4 border border-purple-100 dark:border-purple-900 card-hover hover:shadow-md transition flex flex-col items-center gap-1.5 text-center">
        <span class="text-2xl">⚙️</span>
        <span class="text-sm font-bold text-gray-700 dark:text-gray-200">الإعدادات</span>
      </a>
    </div>

    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 dark:border-gray-700 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-3">
        <h2 class="font-bold text-gray-800 dark:text-white">قائمة التلاميذ</h2>
        <div class="flex items-center gap-3">
          <input type="text" id="searchInput" placeholder="🔍 بحث..." oninput="filterTable()" class="px-3 py-1.5 border border-gray-200 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-lg text-sm outline-none focus:ring-2 focus:ring-emerald-500 w-full sm:w-48">
          <span class="text-xs text-gray-400 dark:text-gray-500 bg-gray-50 dark:bg-gray-700 px-2 py-1 rounded-full"><%= students.length %> تلميذ</span>
        </div>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full" id="studentsTable">
          <thead>
            <tr class="bg-gray-50 dark:bg-gray-800/50 text-right text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              <th class="px-5 py-3">التلميذ</th>
              <th class="px-5 py-3">السورة</th>
              <th class="px-5 py-3">ولي الأمر</th>
              <th class="px-5 py-3">آخر حضور</th>
              <th class="px-5 py-3">الحفظ</th>
              <th class="px-5 py-3">المراجعة</th>
              <th class="px-5 py-3">الإجراءات</th>
            </tr>
          </thead>
          <tbody>
            <% if (students.length === 0) { %>
              <tr><td colspan="7" class="px-5 py-12 text-center text-gray-400 dark:text-gray-500">
                <div class="text-4xl mb-2">📋</div>
                <p>لا يوجد تلاميذ بعد</p>
                <a href="/admin/students/add" class="text-emerald-600 dark:text-emerald-400 hover:text-emerald-800 text-sm font-medium mt-1 inline-block">أضف أول تلميذ</a>
              </td></tr>
            <% } %>
            <% students.forEach(s => { %>
              <tr class="border-t border-gray-100 dark:border-gray-700 hover:bg-emerald-50/50 dark:hover:bg-gray-700/50 transition student-row">
                <td class="px-5 py-4">
                  <div class="flex items-center gap-2">
                    <span class="w-8 h-8 bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-400 rounded-full flex items-center justify-center text-sm font-bold"><%= s.name.charAt(0) %></span>
                    <span class="font-medium text-gray-800 dark:text-white student-name"><%= s.name %></span>
                  </div>
                </td>
                <td class="px-5 py-4"><span class="bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 px-3 py-1 rounded-full text-xs font-medium"><%= s.level || '-' %></span></td>
                <td class="px-5 py-4 text-gray-600 dark:text-gray-400 text-sm"><%= s.parent_name %></td>
                <td class="px-5 py-4">
                  <% if (s.last_date) { %>
                    <span class="inline-flex items-center gap-1.5 <%= s.last_presence ? 'text-emerald-600 dark:text-emerald-400' : 'text-red-500 dark:text-red-400' %> text-sm font-medium">
                      <span class="w-2 h-2 rounded-full <%= s.last_presence ? 'bg-emerald-500' : 'bg-red-500' %>"></span>
                      <%= s.last_presence ? 'حاضر' : 'غائب' %>
                      <span class="text-gray-400 dark:text-gray-500 font-normal"><%= s.last_date %></span>
                    </span>
                  <% } else { %>
                    <span class="text-gray-400 text-sm">-</span>
                  <% } %>
                </td>
                <td class="px-5 py-4 text-gray-600 dark:text-gray-400 text-sm max-w-[150px] truncate"><%= s.last_memorization || '-' %></td>
                <td class="px-5 py-4 text-gray-600 dark:text-gray-400 text-sm max-w-[150px] truncate"><%= s.last_revision || '-' %></td>
                <td class="px-5 py-4">
                  <a href="/admin/students/<%= s.id %>" class="text-emerald-600 dark:text-emerald-400 hover:text-emerald-800 text-sm font-medium bg-emerald-50 dark:bg-emerald-900/30 hover:bg-emerald-100 dark:hover:bg-emerald-900/50 px-3 py-1.5 rounded-lg transition">التفاصيل</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <script>
    function filterTable() {
      const q = document.getElementById('searchInput').value.toLowerCase();
      document.querySelectorAll('.student-row').forEach(r => {
        r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
    }
  </script>
</body>
</html>