<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>بطاقة - <%= student.name %></title>
  <style>
    @media print { @page { margin: 0; size: 85.6mm 54mm; } body { margin: 0; padding: 0; } .no-print { display: none !important; } }
    .card { width: 85.6mm; height: 54mm; font-family: 'Traditional Arabic', 'Amiri', serif; }
  </style>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
  <button onclick="window.print()" class="no-print fixed top-4 left-4 bg-emerald-600 text-white px-6 py-3 rounded-xl shadow-lg text-sm font-bold z-10">🖨️ طباعة</button>
  <a href="/admin/students/<%= student.id %>" class="no-print fixed top-4 right-4 bg-gray-600 text-white px-4 py-3 rounded-xl shadow-lg text-sm z-10">رجوع</a>

  <div class="card bg-white overflow-hidden relative" style="border: 3px solid #047857; border-radius: 10px;">
    <!-- Top bar -->
    <div style="background: linear-gradient(135deg, #047857, #059669); height: 8px;"></div>

    <div style="padding: 6px 10px; display: flex; gap: 8px; align-items: flex-start;">
      <!-- Photo (small, top right) -->
      <div style="width: 50px; height: 50px; border-radius: 8px; overflow: hidden; border: 2px solid #047857; flex-shrink: 0; order: 2;">
        <% if (student.photo) { %>
          <img src="<%= student.photo %>" style="width:100%; height:100%; object-fit: cover;">
        <% } else { %>
          <div style="width:100%; height:100%; background:#e5e7eb; display:flex; align-items:center; justify-content:center; font-size:22px;">🧑‍🎓</div>
        <% } %>
      </div>

      <!-- Info -->
      <div style="flex: 1; order: 0;">
        <div style="font-size: 8px; color: #047857; font-weight: bold;"><%= adminInfo.school_name %></div>
        <div style="font-size: 16px; font-weight: bold; color: #1f2937; margin-top: 1px;"><%= student.name %></div>
        <div style="font-size: 9px; color: #6b7280; margin-top: 5px; line-height: 1.8;">
          <div>👤 <b style="color:#374151;"><%= student.parent_username %></b></div>
          <div>🔑 <b style="color:#374151; font-family:monospace; letter-spacing:1px;"><%= student.parent_password_raw || '' %></b></div>
        </div>
      </div>

      <!-- QR -->
      <div style="width: 52px; height: 52px; flex-shrink: 0; order: 3;"><%- qrSvg %></div>
    </div>

    <div style="font-size: 7px; color: #9ca3af; text-align: center; padding: 0 10px 4px;">امسح QR → أدخل اسم المستخدم وكلمة المرور</div>

    <!-- Bottom bar -->
    <div style="background: linear-gradient(135deg, #059669, #047857); height: 4px;"></div>
  </div>

  <div class="no-print fixed bottom-4 text-xs text-gray-400 text-center w-full">85.6 × 54 mm — حجم بطاقة الهوية</div>
</body>
</html>