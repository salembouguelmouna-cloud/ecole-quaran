<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#047857">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon-192.png">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <title>إضافة حصة - <%= student.name %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css">
  <script>if ('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js');</script>
  <script>
    function toggleMenu() { document.getElementById('mobileMenu').classList.toggle('hidden'); }
    function toggleDark() { document.documentElement.classList.toggle('dark'); localStorage.setItem('dark', document.documentElement.classList.contains('dark')); }
    if (localStorage.getItem('dark') === 'true') document.documentElement.classList.add('dark');
  </script>
</head>
<body class="bg-gray-50 dark:bg-gray-900 min-h-screen transition-colors">
  <nav class="gradient-main text-white shadow-lg">
    <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <span class="w-9 h-9 bg-white/20 rounded-lg flex items-center justify-center text-lg">🕌</span>
        <span class="font-bold text-lg">منارة حميم</span>
      </div>
      <div class="hidden md:flex items-center gap-3">
        <span class="text-emerald-100 text-sm bg-white/10 px-3 py-1 rounded-full"><%= admin.name %></span>
        <a href="/admin/dashboard" class="text-white hover:bg-white/20 px-3 py-1.5 rounded-lg text-sm">لوحة التحكم</a>
        <a href="/admin/students/<%= student.id %>" class="bg-white/20 text-white px-3 py-1.5 rounded-lg text-sm font-medium"><%= student.name %></a>
        <button onclick="toggleDark()" class="text-white hover:bg-white/20 px-3 py-1.5 rounded-lg text-sm">🌓</button>
        <a href="/logout" class="bg-red-500/80 hover:bg-red-500 px-3 py-1.5 rounded-lg text-sm">خروج</a>
      </div>
      <button class="md:hidden text-2xl" onclick="toggleMenu()">☰</button>
    </div>
    <div id="mobileMenu" class="hidden md:hidden px-4 pb-3 space-y-2">
      <a href="/admin/dashboard" class="block hover:bg-white/10 px-3 py-2 rounded-lg text-sm">لوحة التحكم</a>
      <a href="/admin/students/<%= student.id %>" class="block bg-white/20 px-3 py-2 rounded-lg text-sm"><%= student.name %></a>
      <button onclick="toggleDark()" class="block w-full text-right hover:bg-white/10 px-3 py-2 rounded-lg text-sm">🌓 الوضع الليلي</button>
      <a href="/logout" class="block bg-red-500/80 hover:bg-red-500 px-3 py-2 rounded-lg text-sm">خروج</a>
    </div>
  </nav>

  <main class="max-w-2xl mx-auto px-4 py-6">
    <div class="flex items-center gap-3 mb-6">
      <a href="/admin/students/<%= student.id %>" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 text-lg">←</a>
      <h1 class="text-2xl font-bold text-gray-800 dark:text-white">إضافة حصة جديدة</h1>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 p-5 mb-6">
      <div class="flex items-center gap-3">
        <span class="w-10 h-10 bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-400 rounded-xl flex items-center justify-center text-lg font-bold"><%= student.name.charAt(0) %></span>
        <div>
          <p class="font-bold text-gray-800 dark:text-white"><%= student.name %></p>
          <span class="bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 px-2 py-0.5 rounded-full text-xs font-medium"><%= student.level %></span>
        </div>
      </div>
    </div>

    <% if (error) { %>
      <div class="bg-red-50 dark:bg-red-900/30 border-r-4 border-red-500 text-red-700 dark:text-red-400 px-4 py-3 rounded-xl mb-4 text-sm"><%= error %></div>
    <% } %>

    <form method="POST" action="/admin/progress/add/<%= student.id %>" class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 p-6 space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">التاريخ</label>
        <input type="date" name="date" value="<%= new Date().toISOString().split('T')[0] %>"
          class="w-full px-3 py-2.5 border border-gray-200 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-xl outline-none focus:ring-2 focus:ring-emerald-500">
      </div>

      <div class="flex items-center gap-2">
        <input type="checkbox" name="presence" checked id="presence"
          class="w-4 h-4 text-emerald-600 border-gray-300 rounded focus:ring-emerald-500">
        <label for="presence" class="text-sm font-medium text-gray-700 dark:text-gray-300">حاضر</label>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">الحفظ (الآيات المحفوظة)</label>
        <textarea name="memorization" rows="2" placeholder="مثال: الآيات 1-10 من سورة الملك"
          class="w-full px-3 py-2.5 border border-gray-200 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-xl outline-none focus:ring-2 focus:ring-emerald-500"></textarea>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">المراجعة (السور المراجعة)</label>
        <textarea name="revision" rows="2" placeholder="مثال: مراجعة سورة الإخلاص والفلق"
          class="w-full px-3 py-2.5 border border-gray-200 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-xl outline-none focus:ring-2 focus:ring-emerald-500"></textarea>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">السلوك</label>
        <select name="behavior"
          class="w-full px-3 py-2.5 border border-gray-200 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-xl outline-none focus:ring-2 focus:ring-emerald-500">
          <option value="">-</option>
          <option value="جيد">جيد</option>
          <option value="متوسط">متوسط</option>
          <option value="يحتاج تحسين">يحتاج تحسين</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ملاحظات إضافية</label>
        <textarea name="notes" rows="2" placeholder="ملاحظات..."
          class="w-full px-3 py-2.5 border border-gray-200 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-xl outline-none focus:ring-2 focus:ring-emerald-500"></textarea>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-2.5 rounded-xl font-medium transition shadow-md">حفظ</button>
        <a href="/admin/students/<%= student.id %>" class="bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-300 px-6 py-2.5 rounded-xl font-medium transition">إلغاء</a>
      </div>
    </form>
  </main>
</body>
</html>