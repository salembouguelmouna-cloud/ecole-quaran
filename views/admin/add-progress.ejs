<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#047857">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon-192.png">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <title>إضافة حصة - <%= student.name %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>if ('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js');</script>
</head>
<body class="bg-gray-50 min-h-screen">
  <nav class="bg-emerald-700 text-white shadow-lg">
    <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
      <div class="flex items-center gap-2">
        <span class="text-xl">📖</span>
        <span class="font-semibold">مدرسة القرآن</span>
      </div>
      <div class="flex items-center gap-4">
        <span class="text-emerald-100 text-sm"><%= admin.name %></span>
        <a href="/admin/dashboard" class="text-white hover:text-emerald-200 text-sm transition">لوحة التحكم</a>
        <a href="/admin/students/<%= student.id %>" class="text-white hover:text-emerald-200 text-sm transition"><%= student.name %></a>
        <a href="/logout" class="bg-emerald-600 hover:bg-emerald-500 px-3 py-1.5 rounded text-sm transition">خروج</a>
      </div>
    </div>
  </nav>

  <main class="max-w-2xl mx-auto px-4 py-6">
    <h1 class="text-2xl font-bold text-gray-800 mb-2">إضافة حصة جديدة</h1>
    <p class="text-gray-500 mb-6">التلميذ: <strong><%= student.name %></strong> - السورة: <span class="bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full text-xs font-medium"><%= student.level %></span></p>

    <form method="POST" class="bg-white rounded-xl shadow p-6 space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">التاريخ</label>
        <input type="date" name="date" value="<%= new Date().toISOString().split('T')[0] %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none">
      </div>

      <div class="flex items-center gap-2">
        <input type="checkbox" name="presence" checked
          class="w-4 h-4 text-emerald-600 border-gray-300 rounded focus:ring-emerald-500">
        <label class="text-sm font-medium text-gray-700">حاضر</label>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">الحفظ (الآيات المحفوظة)</label>
        <textarea name="memorization" rows="2" placeholder="مثال: الآيات 1-10 من سورة الملك"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none"></textarea>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">المراجعة (السور المراجعة)</label>
        <textarea name="revision" rows="2" placeholder="مثال: مراجعة سورة الإخلاص والفلق"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none"></textarea>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">السلوك</label>
        <select name="behavior"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none">
          <option value="">-</option>
          <option value="جيد">جيد</option>
          <option value="متوسط">متوسط</option>
          <option value="يحتاج تحسين">يحتاج تحسين</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">ملاحظات إضافية</label>
        <textarea name="notes" rows="2" placeholder="ملاحظات..."
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none"></textarea>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-2 rounded-lg font-medium transition">حفظ</button>
        <a href="/admin/students/<%= student.id %>" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-lg font-medium transition">إلغاء</a>
      </div>
    </form>
  </main>
</body>
</html>
